# ========================================
# Python Backend Environment Configuration
# ========================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# ----------------------------------------
# Application
# ----------------------------------------
APP_NAME=comparison-backend
APP_ENV=production  # development, production
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ----------------------------------------
# FastAPI Server
# ----------------------------------------
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=4  # Number of Uvicorn workers
FASTAPI_RELOAD=false  # true for development only

# ----------------------------------------
# Redis (Broker + Result Backend + Cache)
# ----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_BROKER=0  # Celery broker
REDIS_DB_RESULT=1  # Celery result backend
REDIS_DB_CACHE=2  # Application cache
REDIS_PASSWORD=  # Leave empty if no password

# Celery uses these formats:
# CELERY_BROKER_URL will be constructed from REDIS_HOST, REDIS_PORT, REDIS_DB_BROKER
# CELERY_RESULT_BACKEND will be constructed from REDIS_HOST, REDIS_PORT, REDIS_DB_RESULT

# ----------------------------------------
# MinIO Object Storage
# ----------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false  # true for HTTPS
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_RESULTS=results
MINIO_BUCKET_CACHE=cache
MINIO_REGION=us-east-1  # optional

# ----------------------------------------
# Celery
# ----------------------------------------
CELERY_TASK_ALWAYS_EAGER=false  # true for synchronous testing
CELERY_WORKER_CONCURRENCY=4  # Number of parallel tasks per worker
CELERY_TASK_TIME_LIMIT=3600  # Max task runtime in seconds (1 hour)
CELERY_TASK_SOFT_TIME_LIMIT=3300  # Soft limit before hard kill (55 min)
CELERY_RESULT_EXPIRES=86400  # Result TTL in seconds (24 hours)

# ----------------------------------------
# Processing Settings
# ----------------------------------------
# Default thresholds (can be overridden per job)
DEFAULT_SIMHASH_MAX_DIST=5
DEFAULT_JACCARD_NEAR_DUP=0.50
DEFAULT_SEMANTIC_THRESHOLD=0.90
DEFAULT_SEMANTIC_REVIEW_THRESHOLD=0.75
DEFAULT_COSINE_NEAR_DUP=0.85

# Cache settings
CACHE_FINGERPRINTS=true
CACHE_TTL=604800  # 7 days in seconds

# ----------------------------------------
# Ollama (Optional Semantic Similarity)
# ----------------------------------------
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=60  # seconds

# ----------------------------------------
# File Processing
# ----------------------------------------
MAX_FILE_SIZE=524288000  # 500MB in bytes
TEMP_DIR=/tmp/comparison_processing

# OCR Settings
TESSERACT_ENABLED=true
TESSERACT_LANG=eng  # Language code for Tesseract

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_FILE=/var/log/comparison-backend/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=json  # json or text

# ----------------------------------------
# Security (Future)
# ----------------------------------------
# API_KEY=optional_api_key_for_securing_python_endpoints
# ALLOWED_ORIGINS=http://192.168.1.66  # CORS if needed

# ----------------------------------------
# Monitoring (Future)
# ----------------------------------------
# SENTRY_DSN=  # Error tracking
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090
