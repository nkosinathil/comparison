#!/usr/bin/env bash
# =============================================================================
# deploy.conf.example — Central deployment configuration TEMPLATE
# Copy this file to deploy.conf and fill in real values before deploying.
#   cp deploy.conf.example deploy.conf
#   nano deploy.conf        # fill in all __CHANGE_ME__ values
#
# NEVER commit deploy.conf — it contains secrets. It is listed in .gitignore.
#
# MULTI-PLATFORM SAFE: These scripts are designed for servers that already
# host other applications. They will NOT disable existing sites, overwrite
# shared service configs, or restart services they don't own.
# =============================================================================

# ---- Project ----
PROJECT_NAME="comparison"
REPO_URL="https://github.com/nkosinathil/comparison.git"
# Set DEPLOY_REF to the branch or tag you want to deploy.
# Do NOT leave this as "main" if you are deploying a feature/release branch.
# Example: DEPLOY_REF="copilot/update-deploy-windows-cmd"
DEPLOY_REF="__CHANGE_ME__"

# Where the repo is (or will be) cloned on each server.
# The orchestrator (deploy-all.sh) clones automatically to this path.
# When running setup scripts directly, set this to your clone location.
# If empty, auto-detected from script location (works when running from inside the clone).
REPO_ROOT=""

# ---- Servers ----
SSO_HOST="192.168.1.59"
APP_HOST="192.168.1.66"
PYTHON_HOST="192.168.1.90"

SSH_USER_SSO="deploy"
SSH_USER_APP="deploy"
SSH_USER_PY="deploy"

# ---- Public URLs (no trailing slash) ----
APP_BASE_URL="http://file.gismartanalytics.com"
KEYCLOAK_PUBLIC_URL="http://192.168.1.59:8080"

# ---- Keycloak ----
# Set KEYCLOAK_REALM to an EXISTING realm (e.g. "forensics") to reuse it.
# The script will NOT create a new realm if one already exists with this name.
# It will only add/update the client inside the realm.
KEYCLOAK_REALM="forensics"
KEYCLOAK_CLIENT_ID="file.gismartanalytics.com"
KEYCLOAK_ADMIN_USER="__CHANGE_ME__"
KEYCLOAK_ADMIN_PASSWORD="__CHANGE_ME__"
# Client secret will be auto-generated and stored here after keycloak setup:
KEYCLOAK_CLIENT_SECRET=""

# ---- Database (on APP_HOST) ----
# Uses its own database, user, and schema — will not touch other databases.
DB_NAME="comparison_app"
DB_USER="comparison_user"
DB_PASSWORD="__CHANGE_ME__"

# ---- Redis (on PYTHON_HOST) ----
# Uses dedicated DB indices to avoid collisions with other apps sharing Redis.
# Default Redis has DBs 0–15. Pick indices not used by other apps.
REDIS_DB_BROKER="8"
REDIS_DB_RESULT="9"
REDIS_DB_CACHE="10"

# ---- MinIO (on PYTHON_HOST) ----
# Set MINIO_MANAGED=true if this script should install and manage MinIO.
# Set MINIO_MANAGED=false if MinIO is already running (managed by another app).
# When false, just provide the endpoint/credentials of the existing MinIO.
MINIO_MANAGED="true"
MINIO_ACCESS_KEY="__CHANGE_ME__"
MINIO_SECRET_KEY="__CHANGE_ME__"
MINIO_DATA_DIR="/data/comparison-minio"
MINIO_SERVICE_NAME="comparison-minio"

# ---- Shared API key (PHP <-> Python) ----
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY="__CHANGE_ME__"

# ---- Paths ----
APP_DEPLOY_DIR="/var/www/file.gismartanalytics"
PY_DEPLOY_DIR="/opt/comparison"
PY_VENV_DIR="${PY_DEPLOY_DIR}/venv"
PY_LOG_DIR="/var/log/comparison-backend"

# ---- Service user (Python server) ----
PY_SERVICE_USER="comparison"
PY_SERVICE_GROUP="comparison"

# ---- PHP version (auto-detected if empty) ----
PHP_VERSION=""

# ---- Ports ----
FASTAPI_PORT="8000"
REDIS_PORT="6379"
MINIO_PORT="9000"
MINIO_CONSOLE_PORT="9001"
PG_PORT="5432"
