# ========================================
# PHP Application Environment Configuration
# ========================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# ----------------------------------------
# Application
# ----------------------------------------
APP_NAME="MxA - File Comparison"
APP_ENV=production  # development, production
APP_DEBUG=false  # true for development, false for production
APP_URL=http://file.gismartanalytics.com
APP_TIMEZONE=UTC

# ----------------------------------------
# Database (PostgreSQL on same server)
# ----------------------------------------
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=comparison_app
DB_USERNAME=comparison_user
DB_PASSWORD=your_secure_password_here
DB_SCHEMA=public

# ----------------------------------------
# Keycloak SSO (192.168.1.59)
# ----------------------------------------
KEYCLOAK_URL=http://192.168.1.59:8080
KEYCLOAK_REALM=forensics
KEYCLOAK_CLIENT_ID=file.gismartanalytics.com
KEYCLOAK_CLIENT_SECRET=your_client_secret_here
KEYCLOAK_REDIRECT_URI=http://file.gismartanalytics.com/auth/callback
KEYCLOAK_LOGOUT_REDIRECT=http://file.gismartanalytics.com
# TLS verification for Keycloak HTTP calls. Default: true.
# Set to false ONLY for LAN/HTTP development (not reachable via HTTPS yet).
# Must be true in production.
KEYCLOAK_TLS_VERIFY=true
# Allow unsigned JWT decoding as a dev fallback when JWKS is unreachable.
# Default: false. NEVER set to true in production.
KEYCLOAK_ALLOW_INSECURE_JWT_DEV=false

# ----------------------------------------
# Session
# ----------------------------------------
SESSION_DRIVER=database  # database or file
SESSION_LIFETIME=7200  # seconds (2 hours)
SESSION_COOKIE_NAME=comparison_session
SESSION_COOKIE_SECURE=false  # set true when using HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ----------------------------------------
# CSRF Protection
# ----------------------------------------
CSRF_TOKEN_NAME=_csrf_token
CSRF_COOKIE_NAME=csrf_cookie

# ----------------------------------------
# Python API (192.168.1.90)
# ----------------------------------------
PYTHON_API_URL=http://192.168.1.90:8000
PYTHON_API_TIMEOUT=30  # seconds
PYTHON_API_KEY=CHANGE_ME_TO_A_RANDOM_SECRET  # Must match API_KEY in python-backend/.env

# ----------------------------------------
# File Upload Limits
# ----------------------------------------
MAX_UPLOAD_SIZE=524288000  # 500MB in bytes
ALLOWED_EXTENSIONS=eml,msg,pdf,xlsx,xlsm,docx,txt,csv,log,json,xml,html,htm,md,rtf,tif,tiff
UPLOAD_TEMP_DIR=/tmp/comparison_uploads

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_LEVEL=info  # debug, info, warning, error
LOG_FILE=/var/www/file.gismartanalytics/storage/logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_MAX_FILES=5

# ----------------------------------------
# Audit Logging
# ----------------------------------------
AUDIT_ENABLED=true
AUDIT_LOG_FILE=/var/www/file.gismartanalytics/storage/logs/audit.log

# ----------------------------------------
# Cache
# ----------------------------------------
CACHE_DRIVER=file  # file or redis (if using Redis for PHP caching)
CACHE_DIR=/var/www/file.gismartanalytics/storage/cache

# ----------------------------------------
# Rate Limiting (optional)
# ----------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=100  # per time window
RATE_LIMIT_TIME_WINDOW=3600  # seconds (1 hour)

# ----------------------------------------
# Admin Settings
# ----------------------------------------
ADMIN_EMAIL=admin@example.com
SUPPORT_EMAIL=support@example.com
